# Vercel Postgres (заполняется автоматически при подключении в Vercel Dashboard)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Auth
SECRET_KEY=сгенерируй-случайную-строку-32-символа

# Telegram
TELEGRAM_BOT_TOKEN=токен-бота
TELEGRAM_CHAT_ID=твой-chat-id

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=почта@gmail.com
EMAIL_PASSWORD=пароль-приложения
EMAIL_FROM=Кролиководство <почта@gmail.com>

# Cron protection (необязательно)
CRON_SECRET=любая-строка
